<!DOCTYPE html>
<html lang="en" class="h-full" data-controller="dark-mode"<%= ' data-dark-mode-default-theme-value="light"'.html_safe if ENV['BRAINZLAB_LOGO_LIGHT_URL'].present? || ENV['BRAINZLAB_LOGO_DARK_URL'].present? %>>
<head>
  <title>Vault - <%= content_for(:title) || "Secrets Management" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="color-scheme" content="light dark">
  <meta name="turbo-cache-control" content="no-cache">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%# Fonts %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700&display=swap" rel="stylesheet">

  <%# BrainzLab UI Design System %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "dark_mode", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>

  <%# Prevent flash of wrong theme on page load (runs before CSS/Stimulus) %>
  <script>
    (function() {
      var hasCustomLogos = <%= (ENV['BRAINZLAB_LOGO_LIGHT_URL'].present? || ENV['BRAINZLAB_LOGO_DARK_URL'].present?).to_json %>;
      if (hasCustomLogos) localStorage.removeItem('brainzlab-theme');
      var saved = hasCustomLogos ? null : localStorage.getItem('brainzlab-theme');
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      var useDark = !hasCustomLogos && (saved === 'dark' || (!saved && prefersDark));
      document.documentElement.classList.toggle('dark', useDark);
      document.documentElement.classList.toggle('light', !useDark);
    })();
  </script>

  <style>
    body {
      font-family: 'Inter', system-ui, sans-serif;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: var(--scrollbar-track); }
    ::-webkit-scrollbar-thumb { background: var(--scrollbar-thumb); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--scrollbar-thumb-hover); }
  </style>

  <%# Google Analytics - only in production %>
  <% if Rails.env.production? %>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-CXHFR6PC8W"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-CXHFR6PC8W');
    </script>
  <% end %>
</head>
<body class="h-full dm-body-gradient">
  <div class="flex h-full">
    <!-- Sidebar -->
    <aside class="w-64 flex flex-col dm-sidebar-enhanced relative overflow-hidden flex-shrink-0">
      <!-- Decorative gradient blobs -->
      <div class="dm-gradient-mesh">
        <div class="dm-gradient-blob dm-gradient-blob-primary" style="width: 200px; height: 200px; top: -60px; right: -60px;"></div>
        <div class="dm-gradient-blob dm-gradient-blob-secondary" style="width: 150px; height: 150px; bottom: 20%; left: -40px;"></div>
      </div>

      <div class="p-5 border-b dm-border-secondary relative z-10 flex items-center justify-between">
        <%= link_to dashboard_projects_path, class: "flex flex-col items-end gap-1 group" do %>
          <div class="flex items-center">
            <img src="<%= ENV.fetch('BRAINZLAB_LOGO_LIGHT_URL', '/fluyenta-logo-light.png') %>" alt="Fluyenta" class="h-12 dark:hidden">
                <img src="<%= ENV.fetch('BRAINZLAB_LOGO_DARK_URL', '/fluyenta-logo-dark.png') %>" alt="Fluyenta" class="h-12 hidden dark:block">
          </div>
          <span class="text-[10px] font-semibold tracking-wider uppercase px-1.5 py-0.5 rounded" style="color: var(--dm-brand); background: color-mix(in srgb, var(--dm-brand) 12%, transparent);">Vault</span>
        <% end %>
        <%# Dark Mode Toggle %>
        <% unless ENV['BRAINZLAB_LOGO_LIGHT_URL'].present? || ENV['BRAINZLAB_LOGO_DARK_URL'].present? %>
          <%= render Brainzlab::Components::DarkModeToggle.new(data_action: "click->dark-mode#toggle") %>
        <% end %>
      </div>

      <% if @current_project %>
        <!-- Project Selector -->
        <div class="px-4 py-3 border-b dm-border-secondary relative z-10">
          <%= link_to dashboard_projects_path, class: "project-selector flex items-center gap-2 px-2 py-1.5 rounded-lg transition dm-text-secondary" do %>
            <div class="project-initial w-6 h-6 rounded flex items-center justify-center text-xs font-semibold" style="color: var(--dm-brand); background: color-mix(in srgb, var(--dm-brand) 12%, transparent);">
              <%= @current_project.name.first.upcase %>
            </div>
            <span class="flex-1 text-sm font-medium truncate"><%= @current_project.name %></span>
            <svg class="w-4 h-4 dm-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 9l4-4 4 4m0 6l-4 4-4-4"/>
            </svg>
          <% end %>
        </div>

        <!-- Navigation -->
        <nav class="p-4 space-y-1 flex-1 relative z-10">
          <%= link_to dashboard_project_path(@current_project), class: nav_link_class('/overview') do %>
            <%= icon(:overview) %>
            Overview
          <% end %>

          <%= link_to dashboard_project_secrets_path(@current_project), class: nav_link_class('/secrets') do %>
            <%= icon(:secrets) %>
            Secrets
          <% end %>

          <%= link_to dashboard_project_environments_path(@current_project), class: nav_link_class('/environments') do %>
            <%= icon(:environments) %>
            Environments
          <% end %>

          <%= link_to dashboard_project_access_tokens_path(@current_project), class: nav_link_class('/access_tokens') do %>
            <%= icon(:access_tokens) %>
            Access Tokens
          <% end %>

          <%= link_to dashboard_project_audit_logs_path(@current_project), class: nav_link_class('/audit_logs') do %>
            <%= icon(:audit_logs) %>
            Audit Log
          <% end %>

          <%= link_to dashboard_project_connectors_path(@current_project), class: nav_link_class('/connectors') do %>
            <%= icon(:connectors) %>
            Connectors
          <% end %>

          <div class="pt-4 mt-4 border-t dm-border-secondary">
            <%= link_to dashboard_provider_keys_path(project_id: @current_project&.id), class: nav_link_class('/provider_keys') do %>
              <%= icon(:provider_keys) %>
              Provider Keys
            <% end %>

            <%= link_to edit_dashboard_project_path(@current_project), class: nav_link_class('/project_settings') do %>
              <%= icon(:settings) %>
              Project Settings
            <% end %>

            <%= link_to mcp_setup_dashboard_project_path(@current_project), class: nav_link_class('/mcp_setup') do %>
              <%= icon(:mcp) %>
              MCP Setup
            <% end %>

            <%= link_to ssh_keys_dashboard_project_path(@current_project), class: nav_link_class('/ssh_keys') do %>
              <%= icon(:ssh_keys) %>
              SSH Keys
            <% end %>

            <%= link_to dashboard_assistant_index_path, class: nav_link_class('/assistant') do %>
              <svg class="w-[18px] h-[18px] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z"/>
              </svg>
              AI Assistant
            <% end %>
          </div>
        </nav>
      <% else %>
        <nav class="p-4 flex-1 relative z-10">
          <p class="px-3 text-xs font-medium uppercase tracking-wider mb-3 dm-text-muted">Select a project</p>
        </nav>
      <% end %>

      <!-- All Products - Back to Platform -->
      <div class="px-4 pb-2 relative z-10">
        <a href="<%= ENV.fetch('BRAINZLAB_PLATFORM_EXTERNAL_URL', 'https://platform.brainzlab.ai') %>/dashboard<%= "/projects/#{@current_project.platform_project_id}" if @current_project&.persisted? && @current_project.try(:platform_project_id).present? %>"
           class="flex items-center gap-2.5 px-3 py-2 rounded-lg text-[13px] font-medium dm-text-muted hover:dm-text transition-colors dm-surface-hover">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <rect x="3" y="3" width="7" height="7" rx="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <rect x="14" y="3" width="7" height="7" rx="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <rect x="3" y="14" width="7" height="7" rx="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <rect x="14" y="14" width="7" height="7" rx="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          All Products
        </a>
      </div>

      <!-- User Menu -->
      <% if defined?(current_user) && current_user && current_user[:email] %>
        <div class="p-3 border-t dm-border-secondary relative z-10">
          <div class="flex items-center gap-3 px-2 py-2 rounded-xl dm-surface-hover transition">
            <div class="dm-member-avatar w-8 h-8 text-[12px]">
              <%= current_user[:name]&.first&.upcase || current_user[:email]&.first&.upcase || "?" %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-[13px] font-medium truncate dm-text"><%= current_user[:name] || current_user[:email]&.split('@')&.first || "User" %></p>
              <p class="text-[11px] truncate dm-text-muted"><%= current_user[:email] %></p>
            </div>
          </div>
        </div>
      <% end %>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-auto relative">
      <!-- Decorative gradient blobs -->
      <div class="dm-gradient-mesh">
        <div class="dm-gradient-blob dm-gradient-blob-primary" style="width: 500px; height: 500px; top: -150px; right: 5%;"></div>
        <div class="dm-gradient-blob dm-gradient-blob-secondary" style="width: 400px; height: 400px; bottom: 10%; left: -100px;"></div>
        <div class="dm-gradient-blob dm-gradient-blob-cyan" style="width: 300px; height: 300px; top: 40%; right: -80px;"></div>
      </div>

      <% if notice %>
        <div class="m-8 mb-0 px-4 py-3 rounded-xl text-[13px] font-medium flex items-center gap-3 dm-success border dm-fade-in-up relative z-10">
          <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span><%= notice %></span>
        </div>
      <% end %>
      <% if alert %>
        <div class="m-8 mb-0 px-4 py-3 rounded-xl text-[13px] font-medium flex items-center gap-3 dm-error border dm-fade-in-up relative z-10">
          <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
          </svg>
          <span><%= alert %></span>
        </div>
      <% end %>

      <div class="p-8 relative z-10">
        <%= yield %>
      </div>
    </main>
  </div>
</body>
</html>
